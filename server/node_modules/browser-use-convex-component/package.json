{
  "name": "browser-use-convex-component",
  "version": "0.1.1",
  "description": "A Convex component for Browser Use Cloud - automate browser tasks with AI agents",
  "repository": "github:Cheggin/browser-use-convex-component",
  "homepage": "https://github.com/Cheggin/browser-use-convex-component#readme",
  "bugs": {
    "url": "https://github.com/Cheggin/browser-use-convex-component/issues"
  },
  "license": "MIT",
  "keywords": [
    "convex",
    "component",
    "browser-use",
    "browser-automation"
  ],
  "type": "module",
  "types": "./dist/client/index.d.ts",
  "module": "./dist/client/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts"
    },
    "./_generated/component": {
      "types": "./dist/component/_generated/component.d.ts"
    },
    "./test": "./src/test.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "predev": "npm run build:codegen",
    "dev": "npm-run-all --parallel dev:codegen dev:tsc dev:backend",
    "dev:codegen": "npx convex codegen --component-dir ./src/component --watch",
    "dev:tsc": "tsc --watch",
    "dev:backend": "npx convex dev --typecheck-components",
    "build:codegen": "npx convex codegen --component-dir ./src/component",
    "build": "npm run build:codegen && tsc",
    "build:clean": "rm -rf dist *.tsbuildinfo && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "convex": "^1.31.7"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "convex": "^1.31.7",
    "convex-test": "^0.0.41",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.7.0",
    "vitest": "^3.0.0"
  }
}
